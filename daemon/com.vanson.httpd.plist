<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.vanson.httpd</string>
    <key>ProgramArguments</key>
    <array>
        <string>/var/jb/usr/local/bin/vansonmodd</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/jb/var/log/vansonmodd.log</string>
    <key>StandardErrorPath</key>
    <string>/var/jb/var/log/vansonmodd_err.log</string>
</dict>
</plist>
